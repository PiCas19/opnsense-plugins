######################################################
# OPNsense Management API - Environment Template
# Replace all placeholders with your actual values
######################################################

### Application Core ###
NODE_ENV=development
PORT=3000
API_HOST=0.0.0.0
API_BASE_PATH=/api/v1
APP_DEBUG=false
LOG_LEVEL=info
REQUEST_SIZE_LIMIT=10mb
ENABLE_SWAGGER=true

# Application name and version
APP_NAME="OPNsense Management API"
APP_VERSION=1.0.0

### Network Configuration ###
# Management VM in LAN: 192.168.216.50
# Docker containers in DMZ: 172.16.216.0/24
# OPNsense interfaces: WAN, LAN (192.168.216.1), DMZ (172.16.216.1)

### Database Configuration ###
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=opnsense_user
POSTGRES_PASSWORD=SecurePassword123!
POSTGRES_DB=opnsense_mgmt
POSTGRES_SSL_MODE=prefer
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
POSTGRES_TIMEOUT=30000

# Database connection retry
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5000

### OPNsense API Credentials ###
# Access OPNsense WebGUI > System > Access > Users > API Keys
OPNSENSE_BASE_URL=https://192.168.216.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here
OPNSENSE_SSL_VERIFY=false
OPNSENSE_TIMEOUT=30000

# OPNsense API configuration
OPNSENSE_CACHE_TIMEOUT=60
MAX_API_RETRIES=3
API_REQUEST_TIMEOUT=10000

### Authentication & Security ###
JWT_SECRET=generate_strong_secret_here_min_32_chars_12345678901234567890
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=opnsense-api
JWT_AUDIENCE=opnsense-users

# Password security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Session & Cookie security
COOKIE_SECRET=another_secure_secret_for_cookies_1234567890
SESSION_SECRET=session_secret_min_32_chars_1234567890123456

### Redis Cache ###
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=SecureRedisPassword123!
REDIS_DB=0
REDIS_TTL=3600
REDIS_CONNECTION_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=3000

# Cache timeouts for different services
MONITORING_CACHE_TIMEOUT=60
RULES_CACHE_TIMEOUT=60
POLICY_CACHE_TIMEOUT=60
ALERT_CACHE_TIMEOUT=60

### CORS & Security Headers ###
CORS_ORIGIN=http://192.168.216.50:3000,http://192.168.216.50:3001,http://localhost:3000
CORS_CREDENTIALS=true
TRUST_PROXY=1
HELMET_ENABLED=true
CSRF_ENABLED=true

### Rate Limiting ###
# Global rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESS=false

# API specific rate limits
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MONITORING_MAX=300
RATE_LIMIT_CONFIG_MAX=50

### Health Checks & Monitoring ###
HEALTH_CHECK_INTERVAL=30000
SHUTDOWN_TIMEOUT=10000
METRICS_ENABLED=true
METRICS_ALLOWED_IPS=192.168.216.50,172.16.216.1,127.0.0.1

# Performance monitoring
SLOW_OPERATION_THRESHOLD=1000
MEMORY_THRESHOLD_MB=500

### Monitoring Integration ###
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SecureGrafanaPassword123!
GRAFANA_ENABLED=true

NAGIOS_HOST=nagios
NAGIOS_PORT=8080
NAGIOS_USER=nagiosadmin
NAGIOS_PASS=SecureNagiosPassword123!
NAGIOS_ENABLED=true

### System Thresholds ###
# Monitoring thresholds (percentages)
CPU_THRESHOLD=90
MEMORY_THRESHOLD=85
DISK_THRESHOLD=95
NETWORK_THRESHOLD=1000000000

### Backup Configuration ###
BACKUP_DIR=/var/backups
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_ENABLED=true

### Logging Configuration ###
LOG_FILE_PATH=/var/log/opnsense-api
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m
LOG_DATE_PATTERN=YYYY-MM-DD

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_INCLUDE_REQUEST_BODY=false
AUDIT_INCLUDE_RESPONSE_BODY=false
AUDIT_EXCLUDE_PATHS=/health,/metrics

### Error Handling ###
ERROR_STACK_TRACE=false
DETAILED_ERRORS=false
ERROR_REPORTING_ENABLED=true

### Service Configuration ###
# Retry configuration
MAX_RETRIES=3
RETRY_DELAY=1000
EXPONENTIAL_BACKOFF=true

# Timeout configuration
DEFAULT_TIMEOUT=30000
DATABASE_TIMEOUT=30000
CACHE_TIMEOUT=5000

### Email Configuration (Optional) ###
# For alerts and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

### Webhook Configuration (Optional) ###
# For external integrations
WEBHOOK_SECRET=webhook_secret_key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

### SSL/TLS Configuration ###
# For HTTPS mode (optional)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/ssl/certs/api.crt
SSL_KEY_PATH=/etc/ssl/private/api.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

### Development & Debug ###
# Development only settings
DEBUG_SQL=false
DEBUG_API_CALLS=false
MOCK_OPNSENSE=false
DEVELOPMENT_CORS=true

# Testing configuration
TEST_DB_NAME=opnsense_mgmt_test
TEST_REDIS_DB=1

######################################################
# Network Architecture Notes:
#
# Internet → OPNsense WAN
# ↓
# OPNsense (192.168.216.1)
# ↓
# LAN (192.168.216.0/24) ← Management VM (192.168.216.50)
# ↓ ↑
# DMZ (172.16.216.0/24) ← Docker Stack
#
# Required OPNsense Firewall Rules:
# 1. LAN → DMZ: Allow 192.168.216.50 to 172.16.216.0/24 on ports 3000,3001,9090,8080,8081
# 2. DMZ → LAN: Allow Docker containers to OPNsense API (192.168.216.1:443)
# 3. DMZ → Internet: Allow outbound for updates (optional)
#
# Port Mapping on Management VM:
# - Host 192.168.216.50:3000 → Container API
# - Host 192.168.216.50:3001 → Container Grafana
# - Host 192.168.216.50:9090 → Container Prometheus
# - Host 192.168.216.50:8080 → Container Nagios
# - Host 192.168.216.50:8081 → Container Swagger UI
######################################################

### Production Deployment Notes ###
#
# 1. Security Checklist:
#    - Change all default passwords
#    - Generate strong JWT secrets (min 32 chars)
#    - Set NODE_ENV=production
#    - Enable SSL/TLS certificates
#    - Configure proper CORS origins
#    - Set up IP whitelisting for metrics
#
# 2. Performance Tuning:
#    - Adjust database pool sizes based on load
#    - Configure Redis memory limits
#    - Set appropriate cache timeouts
#    - Monitor and adjust rate limits
#
# 3. Monitoring Setup:
#    - Configure Prometheus scrape intervals
#    - Set up Grafana dashboards
#    - Configure alert thresholds
#    - Set up log rotation
#
# 4. High Availability:
#    - Use Redis Sentinel/Cluster for cache
#    - Configure PostgreSQL replication
#    - Set up load balancer health checks
#    - Implement graceful shutdowns
#
######################################################