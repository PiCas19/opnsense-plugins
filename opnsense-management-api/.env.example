######################################################
# OPNsense Management API - Environment Configuration
# Professional Network Security Implementation
# Replace all placeholders with your actual values
######################################################

### Application Core ###
NODE_ENV=production
PORT=3000
API_HOST=0.0.0.0
DMZ_HOST_IP=172.16.216.20
LAN_HOST_IP=192.168.216.50
API_BASE_PATH=/api/v1
APP_DEBUG=false
LOG_LEVEL=info
REQUEST_SIZE_LIMIT=10mb
ENABLE_SWAGGER=true

# Application metadata
APP_NAME="OPNsense Management API"
APP_VERSION=1.0.0

### Network Configuration ###
# Management VM in LAN: 192.168.216.50
# Docker containers in DMZ: 172.16.216.0/24
# OPNsense interfaces: WAN, LAN (192.168.216.1), DMZ (172.16.216.1)

### Database Configuration ###
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=opnsense_user
POSTGRES_PASSWORD=SecurePassword123!
POSTGRES_DB=opnsense_mgmt
POSTGRES_SSL_MODE=prefer
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
POSTGRES_TIMEOUT=30000

# Database connection retry
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5000

### OPNsense API Credentials ###
# Access OPNsense WebGUI > System > Access > Users > API Keys
OPNSENSE_BASE_URL=https://192.168.216.1
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here
OPNSENSE_SSL_VERIFY=false
OPNSENSE_TIMEOUT=30000

# OPNsense API configuration
OPNSENSE_CACHE_TIMEOUT=60
MAX_API_RETRIES=3
API_REQUEST_TIMEOUT=10000

### Authentication & Security ###
JWT_SECRET=generate_strong_secret_here_min_32_chars_12345678901234567890
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=opnsense-api
JWT_AUDIENCE=opnsense-users

# Password security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Session & Cookie security
COOKIE_SECRET=another_secure_secret_for_cookies_1234567890
SESSION_SECRET=session_secret_min_32_chars_1234567890123456

### Redis Cache ###
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=SecureRedisPassword123!
REDIS_DB=0
REDIS_TTL=3600
REDIS_CONNECTION_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=3000

# Cache timeouts for different services
MONITORING_CACHE_TIMEOUT=60
RULES_CACHE_TIMEOUT=60
POLICY_CACHE_TIMEOUT=60
ALERT_CACHE_TIMEOUT=60

### CORS & Security Headers ###
CORS_ORIGIN=http://192.168.216.50:3000,http://192.168.216.50:3001,http://localhost:3000
CORS_CREDENTIALS=true
TRUST_PROXY=1
HELMET_ENABLED=true
CSRF_ENABLED=true

### Rate Limiting ###
# Global rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESS=false

# API specific rate limits
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MONITORING_MAX=300
RATE_LIMIT_CONFIG_MAX=50

### Health Checks & Monitoring ###
HEALTH_CHECK_INTERVAL=30000
SHUTDOWN_TIMEOUT=10000
METRICS_ENABLED=true
METRICS_ALLOWED_IPS=192.168.216.50,172.16.216.1,127.0.0.1

# Performance monitoring
SLOW_OPERATION_THRESHOLD=1000
MEMORY_THRESHOLD_MB=500

### Docker Compose Configuration ###
# Profile selection for multi-environment deployment
COMPOSE_PROFILES=dmz
COMPOSE_PROJECT_NAME=opnsense-management

### Monitoring Integration ###
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SecureGrafanaPassword123!
GRAFANA_ENABLED=true

NAGIOS_HOST=nagios
NAGIOS_PORT=8080
NAGIOS_USER=nagiosadmin
NAGIOS_PASS=SecureNagiosPassword123!
NAGIOS_ENABLED=true

### Container Resource Limits ###
# Memory limits for monitoring containers
GRAFANA_MEMORY_LIMIT=512m
PROMETHEUS_MEMORY_LIMIT=1g
NAGIOS_MEMORY_LIMIT=256m
NGINX_MEMORY_LIMIT=128m

# CPU limits
GRAFANA_CPU_LIMIT=0.5
PROMETHEUS_CPU_LIMIT=1.0
NAGIOS_CPU_LIMIT=0.3
NGINX_CPU_LIMIT=0.2

### Enhanced Grafana Configuration ###
# Security settings
GF_USERS_ALLOW_SIGN_UP=false
GF_USERS_ALLOW_ORG_CREATE=false
GF_AUTH_ANONYMOUS_ENABLED=false
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false

# Reverse proxy settings
GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true

### Enhanced Prometheus Configuration ###
# Data retention policies
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# External URL for reverse proxy
PROMETHEUS_EXTERNAL_URL=/prometheus/

# Prometheus job configurations
PROMETHEUS_SCRAPE_TIMEOUT=10s
PROMETHEUS_METRICS_PATH=/metrics

### Nginx Configuration ###
# Basic authentication
NGINX_AUTH_USER=admin
NGINX_AUTH_PASS=SuperPassword!

# Rate limiting
NGINX_RATE_LIMIT=10r/s
NGINX_BURST_LIMIT=20
NGINX_RATE_LIMIT_ZONE_SIZE=10m

# SSL/TLS settings
NGINX_SSL_PROTOCOLS="TLSv1.2 TLSv1.3"
NGINX_SSL_CIPHERS="ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256"

# Security headers
NGINX_HSTS_MAX_AGE=31536000
NGINX_CSP_POLICY="default-src 'self'"

# Network configuration
NGINX_UPSTREAM_KEEPALIVE=32
NGINX_PROXY_TIMEOUT=60s

### System Thresholds ###
# Monitoring thresholds (percentages)
CPU_THRESHOLD=90
MEMORY_THRESHOLD=85
DISK_THRESHOLD=95
NETWORK_THRESHOLD=1000000000

### SSL Certificate Configuration ###
# For automatic certificate generation
SSL_COUNTRY=CH
SSL_STATE=Ticino
SSL_CITY=Viganello
SSL_ORGANIZATION="OPNsense Management System"
SSL_ORGANIZATIONAL_UNIT="Network Security Infrastructure"
SSL_COMMON_NAME=opnsense-monitoring.local
SSL_EMAIL=admin@opnsense-monitoring.local
SSL_VALIDITY_DAYS=365
SSL_KEY_SIZE=2048

### Timezone Configuration ###
TZ=Europe/Zurich

### Backup Configuration ###
BACKUP_DIR=/var/backups
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_ENABLED=true

# Container data backup paths
GRAFANA_BACKUP_PATH=/var/backups/grafana
PROMETHEUS_BACKUP_PATH=/var/backups/prometheus
POSTGRES_BACKUP_PATH=/var/backups/postgres

# Maintenance windows
MAINTENANCE_WINDOW_START=02:00
MAINTENANCE_WINDOW_END=04:00
MAINTENANCE_TIMEZONE=Europe/Zurich

### Logging Configuration ###
LOG_FILE_PATH=/var/log/opnsense-api
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m
LOG_DATE_PATTERN=YYYY-MM-DD

# Individual service log levels
GRAFANA_LOG_LEVEL=info
PROMETHEUS_LOG_LEVEL=info
NAGIOS_LOG_LEVEL=info
NGINX_LOG_LEVEL=warn

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_INCLUDE_REQUEST_BODY=false
AUDIT_INCLUDE_RESPONSE_BODY=false
AUDIT_EXCLUDE_PATHS=/health,/metrics

# Log rotation settings
LOG_MAX_FILE_SIZE=100M
LOG_MAX_BACKUP_FILES=5
LOG_COMPRESS_ROTATED=true

### Health Check Configuration ###
# Container health check intervals
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

### Network Configuration ###
# Docker network settings
DOCKER_NETWORK_LAN_SUBNET=172.20.0.0/16
DOCKER_NETWORK_DMZ_SUBNET=172.21.0.0/16

### Error Handling ###
ERROR_STACK_TRACE=false
DETAILED_ERRORS=false
ERROR_REPORTING_ENABLED=true

### Service Configuration ###
# Retry configuration
MAX_RETRIES=3
RETRY_DELAY=1000
EXPONENTIAL_BACKOFF=true

# Timeout configuration
DEFAULT_TIMEOUT=30000
DATABASE_TIMEOUT=30000
CACHE_TIMEOUT=5000

### Volume Management ###
# Named volume drivers
POSTGRES_VOLUME_DRIVER=local
REDIS_VOLUME_DRIVER=local
GRAFANA_VOLUME_DRIVER=local
PROMETHEUS_VOLUME_DRIVER=local

# Volume backup labels
BACKUP_POSTGRES_DATA=true
BACKUP_GRAFANA_DATA=true
BACKUP_PROMETHEUS_DATA=true
BACKUP_REDIS_DATA=true

### Container Restart Policies ###
# Restart behavior for production
RESTART_POLICY=unless-stopped
RESTART_MAX_ATTEMPTS=5
RESTART_DELAY=10s

### Email Configuration (Optional) ###
# For alerts and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

### Webhook Configuration (Optional) ###
# For external integrations
WEBHOOK_SECRET=webhook_secret_key
WEBHOOK_TIMEOUT=30s
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5s

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

### SSL/TLS Configuration ###
# For HTTPS mode (optional)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/ssl/certs/api.crt
SSL_KEY_PATH=/etc/ssl/private/api.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

### Development & Debug ###
# Development only settings
DEBUG_SQL=false
DEBUG_API_CALLS=false
MOCK_OPNSENSE=false
DEVELOPMENT_CORS=true

# API documentation
SWAGGER_ENABLED=true
SWAGGER_BASE_URL=http://192.168.216.50:3000

# Debug and profiling
NODE_INSPECTOR_ENABLED=false
NODE_INSPECTOR_PORT=9229
PROFILING_ENABLED=false

# Testing configuration
TEST_DB_NAME=opnsense_mgmt_test
TEST_REDIS_DB=1

### External Integrations ###
# External monitoring services
EXTERNAL_MONITORING_ENABLED=false
EXTERNAL_MONITORING_URL=https://monitoring.example.com
EXTERNAL_MONITORING_API_KEY=your_external_monitoring_key

# Alert manager (if used)
ALERTMANAGER_ENABLED=false
ALERTMANAGER_URL=http://alertmanager:9093

### Compliance and Auditing ###
# Compliance settings
GDPR_COMPLIANCE_ENABLED=true
AUDIT_RETENTION_DAYS=90
SECURITY_SCAN_ENABLED=false

# Data anonymization
ANONYMIZE_LOGS=false
ANONYMIZE_METRICS=false

######################################################
# Network Architecture Overview:
#
# Internet → OPNsense WAN
# ↓
# OPNsense Firewall (192.168.216.1)
# ↓
# LAN Network (192.168.216.0/24) ← Management VM (192.168.216.50)
# ↓ ↑
# DMZ Network (172.16.216.0/24) ← Docker Stack
#
# Required OPNsense Firewall Rules:
# 1. LAN → DMZ: Allow 192.168.216.50 to 172.16.216.0/24 
#    Ports: 3000 (API), 3001 (Grafana), 9090 (Prometheus), 8080 (Nagios)
# 2. DMZ → LAN: Allow Docker containers to OPNsense API (192.168.216.1:443)
# 3. DMZ → Internet: Allow outbound for updates and external integrations
#
# Service Port Mapping:
# - API: 192.168.216.50:3000 → opnsense-api:3000
# - Grafana: https://172.16.216.20/grafana/ → grafana:3000
# - Prometheus: https://172.16.216.20/prometheus/ → prometheus:9090
# - Nagios: https://172.16.216.20/nagios/ → nagios:80
# - Nginx: 172.16.216.20:443/80 → nginx:443/80
######################################################

### Production Deployment Checklist ###
#
# Security Configuration:
# ✓ Change all default passwords to strong, unique values
# ✓ Generate cryptographically secure JWT secrets (minimum 64 characters)
# ✓ Set NODE_ENV=production for optimized performance
# ✓ Enable SSL/TLS certificates for all external communications
# ✓ Configure proper CORS origins (remove wildcards)
# ✓ Set up IP whitelisting for metrics and administrative endpoints
# ✓ Enable audit logging for compliance and security monitoring
#
# Performance Optimization:
# ✓ Adjust database connection pool sizes based on expected load
# ✓ Configure Redis memory limits and eviction policies
# ✓ Set appropriate cache timeouts for different data types
# ✓ Monitor and adjust rate limits based on usage patterns
# ✓ Configure log rotation to prevent disk space issues
#
# Monitoring and Alerting:
# ✓ Configure Prometheus scrape intervals for optimal performance
# ✓ Set up Grafana dashboards for system and application metrics
# ✓ Configure alert thresholds for critical system parameters
# ✓ Set up external webhook integrations for incident response
# ✓ Test backup and recovery procedures regularly
#
# High Availability and Disaster Recovery:
# ✓ Implement Redis Sentinel or Cluster for cache high availability
# ✓ Configure PostgreSQL streaming replication for data redundancy
# ✓ Set up load balancer health checks for service availability
# ✓ Implement graceful shutdown procedures for maintenance
# ✓ Document and test disaster recovery procedures quarterly
#
# Operational Security:
# ✓ Regular security updates for base images and dependencies
# ✓ Network segmentation and firewall rule validation
# ✓ Container security scanning in CI/CD pipeline
# ✓ Secrets management using external vault or encrypted storage
# ✓ Regular penetration testing and vulnerability assessments
######################################################