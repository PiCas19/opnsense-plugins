          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "vis": false
            }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Critical Alerts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "High Alerts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Medium Alerts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Low Alerts"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "opnsense_security_alerts_total{severity=\"critical\"}",
          "legendFormat": "Critical Alerts",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "opnsense_security_alerts_total{severity=\"high\"}",
          "legendFormat": "High Alerts",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "opnsense_security_alerts_total{severity=\"medium\"}",
          "legendFormat": "Medium Alerts",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "opnsense_security_alerts_total{severity=\"low\"}",
          "legendFormat": "Low Alerts",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "Total Security Alerts by Severity",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "Average time to respond to alerts",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "vis": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "histogram_quantile(0.95, rate(opnsense_alert_response_duration_seconds_bucket{action=\"acknowledge\"}[10m]))",
          "legendFormat": "Acknowledge Time (95th percentile)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "builder",
          "expr": "histogram_quantile(0.95, rate(opnsense_alert_response_duration_seconds_bucket{action=\"resolve\"}[10m]))",
          "legendFormat": "Resolve Time (95th percentile)",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Alert Response Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "simplejson-datasource",
        "uid": "json-ds"
      },
