      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": {
            "type": "simplejson-datasource",
            "uid": "json-ds"
          },
          "method": "GET",
          "refId": "A",
          "url": "/monitoring/alerts?status=active&limit=50"
        }
      ],
      "title": "Active Security Alerts",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "metadata": true,
              "notifications_sent": true,
              "occurrence_count": true
            },
            "indexByName": {
              "created_at": 6,
              "id": 0,
              "message": 2,
              "severity": 3,
              "source": 4,
              "source_ip": 5,
              "status": 7,
              "title": 1,
              "type": 8
            },
            "renameByName": {
              "created_at": "Created At",
              "id": "ID",
              "message": "Message",
              "severity": "Severity",
              "source": "Source",
              "source_ip": "Source IP",
              "status": "Status",
              "title": "Title",
              "type": "Type"
            }
          }
        }
      ],
      "type": "table"
