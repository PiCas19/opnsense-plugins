          "rawQuery": true,
          "rawSql": "SELECT \n    date_trunc('hour', al.timestamp) as time,\n    al.action,\n    COUNT(*) as count\nFROM audit_logs al\nWHERE al.timestamp >= NOW() - INTERVAL '24 hours'\n    AND (al.resource LIKE '%firewall%' OR al.resource LIKE '%rule%')\nGROUP BY date_trunc('hour', al.timestamp), al.action\nORDER BY time",
