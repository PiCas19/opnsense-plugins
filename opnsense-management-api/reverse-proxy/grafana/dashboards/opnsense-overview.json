          "rawQuery": true,
          "rawSql": "SELECT \n    al.timestamp,\n    al.action,\n    al.resource,\n    al.details::json->>'description' as description,\n    u.username\nFROM audit_logs al\nLEFT JOIN users u ON al.user_id = u.user_id\nWHERE al.resource LIKE '%firewall%' OR al.resource LIKE '%rule%'\nORDER BY al.timestamp DESC\nLIMIT 15",
