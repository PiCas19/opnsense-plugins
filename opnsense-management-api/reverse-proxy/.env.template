# Dominio/FQDN pubblico (o IP WAN) del reverse-proxy
PUBLIC_FQDN=fw.example.com

# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=UnaPasswordMoltoForte123!
GF_SERVER_ROOT_URL=https://fw.example.com/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_LOG_LEVEL=info

# --- Wrapper su LAN ---
OPNSENSE_API_HOST=192.168.216.50
OPNSENSE_API_PORT=3000
OPNSENSE_API_URL=http://192.168.216.50:3000

# --- Nginx ---
NGINX_CLIENT_MAX_BODY_SIZE=10m

# --- Basic Auth (solo per /api-docs se vuoi) ---
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=cambia_questa

# (Opzionale) DB esterno per Grafana: se non lo vuoi, NON settare questi e Grafana userà SQLite
POSTGRES_HOST=192.168.216.50
POSTGRES_PORT=5432
POSTGRES_USER=opnsense
POSTGRES_PASSWORD=la_password_del_DB_wrapper
POSTGRES_DB=opnsense_mgmt
GRAFANA_DB=grafana