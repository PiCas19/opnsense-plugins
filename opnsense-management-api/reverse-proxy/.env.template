# ---------- DMZ API ----------
DMZ_HOST=0.0.0.0
DMZ_PORT=8000
LOG_LEVEL=INFO

# single demo user (JWT)
DEMO_USERNAME=admin
DEMO_PASSWORD=changeme
JWT_SECRET=change_this_ultra_secret_key
JWT_EXPIRE_MINUTES=60

# ---------- WRAPPER (INTERNAL) ----------
# URL completo fino a /api del wrapper interno
WRAPPER_BASE_URL=http://10.0.1.50:8080/api
WRAPPER_VERIFY_SSL=false
WRAPPER_TIMEOUT=5

# ---------- NGINX ----------
# se vuoi anche 80→443 redirect, abilitalo in nginx.conf
SERVER_NAME=demo.example.com