# === Edge/FQDN del proxy ===
PUBLIC_FQDN=fw.example.com

# === Wrapper (LAN) da pubblicare ===
WRAPPER_SCHEME=http
WRAPPER_HOST=192.168.216.50:3000

# === Nginx ===
NGINX_CLIENT_MAX_BODY_SIZE=10m

# === Basic Auth del proxy (unico utente ammesso) ===
BASIC_AUTH_USER=monitoring-api
BASIC_AUTH_PASSWORD=CambiaSubito_!

# === DNS del container (DMZ) ===
DOCKER_DNS=172.16.216.1

# Porte (se vuoi cambiarle)
HTTP_PORT=80
HTTPS_PORT=443