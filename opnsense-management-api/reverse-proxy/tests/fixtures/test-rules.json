  "test_scenarios": {
    "create_update_delete_cycle": {
      "description": "Test complete lifecycle of a firewall rule",
      "steps": [
        {
          "action": "create",
          "rule": {
            "interface": "wan",
            "direction": "in",
            "action": "pass",
            "protocol": "tcp",
            "source_address": "any",
            "source_port": "any",
            "destination_address": "192.168.1.200",
            "destination_port": "8080",
            "description": "Test rule for lifecycle testing",
            "enabled": true
          }
        },
        {
          "action": "update",
          "field": "description",
          "value": "Updated test rule description"
        },
        {
          "action": "toggle",
          "expected_enabled": false
        },
        {
          "action": "toggle",
          "expected_enabled": true
        },
        {
          "action": "delete"
        }
      ]
    },
    
    "performance_test_rules": {
      "description": "Rules for performance testing",
      "count": 100,
      "rule_template": {
        "interface": "wan",
        "direction": "in",
        "action": "pass",
        "protocol": "tcp",
        "source_address": "any",
        "source_port": "any",
        "destination_address": "192.168.1.{index}",
        "destination_port": "{port}",
        "description": "Performance test rule {index}",
        "enabled": true
      },
      "variations": {
        "ip_range": "192.168.1.100-199",
        "port_range": "8000-8099"
      }
    },
    
    "stress_test_scenarios": {
      "concurrent_creates": {
        "description": "Create multiple rules simultaneously",
        "concurrent_requests": 10,
        "rule_count": 50
      },
      "rapid_toggles": {
        "description": "Rapidly enable/disable rules",
        "iterations": 20,
        "delay_ms": 100
      },
      "bulk_operations": {
        "description": "Test bulk enable/disable operations",
        "rule_count": 100,
        "operations": ["enable_all", "disable_all", "enable_all"]
      }
    }
  },
  
