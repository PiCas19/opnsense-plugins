{
  "name": "opnsense-reverse-proxy-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for OPNsense Reverse Proxy with Nginx and Grafana",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:nginx": "jest --testPathPattern=nginx",
    "test:grafana": "jest --testPathPattern=grafana",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "setup": "node setup/testSetup.js",
    "cleanup": "node setup/cleanup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "opnsense",
    "nginx",
    "grafana",
    "reverse-proxy",
    "firewall",
    "testing",
    "e2e"
  ],
  "author": "OPNsense Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "eslint": "^8.50.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "https": "^1.0.0",
    "playwright": "^1.38.0",
    "puppeteer": "^21.3.6",
    "supertest": "^6.3.3",
    "ws": "^8.14.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/setup/testSetup.js"
    ],
    "testMatch": [
      "**/e2e/**/*.test.js",
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "e2e/**/*.js",
      "!e2e/**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 30000,
    "maxWorkers": 2,
    "verbose": true,
    "detectOpenHandles": true,
    "forceExit": true
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}