          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n    CASE \n        WHEN COUNT(*) > 0 AND MAX(last_check) > NOW() - INTERVAL '5 minutes' THEN 1\n        ELSE 0\n    END as status\nFROM (\n    SELECT MAX(created_at) as last_check\n    FROM audit_logs\n    WHERE resource LIKE '%health%' OR action = 'health_check'\n) t",
          "refId": "A"
        }
      ],
      "title": "API Status",
      "type": "stat"
