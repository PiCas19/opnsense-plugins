  "api_endpoints": {
    "test_endpoints": [
      {
        "method": "GET",
        "path": "/api/v1/health",
        "expected_status": 200,
        "auth_required": false
      },
      {
        "method": "GET", 
        "path": "/api/v1/firewall/rules",
        "expected_status": 200,
        "auth_required": true,
        "required_permission": "firewall:read"
      },
      {
        "method": "POST",
        "path": "/api/v1/firewall/rules", 
        "expected_status": 201,
        "auth_required": true,
        "required_permission": "firewall:write"
      },
      {
        "method": "PUT",
        "path": "/api/v1/firewall/rules/{id}",
        "expected_status": 200,
        "auth_required": true,
        "required_permission": "firewall:write"
      },
      {
        "method": "DELETE",
        "path": "/api/v1/firewall/rules/{id}",
        "expected_status": 200,
        "auth_required": true,
        "required_permission": "firewall:write"
      },
      {
        "method": "POST",
        "path": "/api/v1/firewall/apply",
        "expected_status": 200,
        "auth_required": true,
        "required_permission": "firewall:write"
      }
    ]
  },
