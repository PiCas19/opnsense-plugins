{
  "scripts": {
    "test": "jest --config=tests/setup/jest.config.js",
    "test:watch": "jest --config=tests/setup/jest.config.js --watch",
    "test:coverage": "jest --config=tests/setup/jest.config.js --coverage",
    "test:unit": "jest --config=tests/setup/jest.config.js --testPathPattern=tests/unit",
    "test:integration": "jest --config=tests/setup/jest.config.js --testPathPattern=tests/integration",
    "test:unit:watch": "jest --config=tests/setup/jest.config.js --testPathPattern=tests/unit --watch",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --config=tests/setup/jest.config.js --runInBand",
    "test:clear-cache": "jest --config=tests/setup/jest.config.js --clearCache",
    "test:update-snapshots": "jest --config=tests/setup/jest.config.js --updateSnapshot"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "@jest/test-sequencer": "^29.7.0",
    "supertest": "^7.0.0"
  }
}