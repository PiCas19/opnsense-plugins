{
  "name": "opnsense-firewall-api",
  "version": "1.0.0",
  "description": "API per gestione regole firewall OPNsense",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node src/utils/migrate.js",
    "seed": "node src/utils/seed.js",
    "db:init": "node src/utils/db-manager.js init",
    "db:reset": "node src/utils/db-manager.js reset",
    "db:drop": "node src/utils/db-manager.js drop",
    "db:recreate": "node src/utils/db-manager.js recreate",
    "db:status": "node src/utils/db-manager.js status",
    "db:tables": "node src/utils/db-manager.js tables",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf node_modules package-lock.json",
    "fresh-install": "npm run clean && npm install",
    "update-check": "npm outdated"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.13.3",
    "axios": "^1.7.7",
    "winston": "^3.14.2",
    "compression": "^1.7.4",
    "express-async-handler": "^1.2.0",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "uuid": "^10.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "opnsense",
    "firewall",
    "api",
    "nodejs",
    "docker"
  ],
  "author": "Pierpaolo casati SUPSI",
  "license": "MIT"
}