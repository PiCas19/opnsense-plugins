{
  "name": "opnsense-management-api",
  "version": "1.0.0",
  "description": "RESTful API wrapper for OPNsense firewall management with monitoring integration",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js --inspect=0.0.0.0:9229",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:unit": "jest --testPathPattern=tests/unit",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js'",
    "docs:generate": "swagger-jsdoc -d swagger.config.js src/routes/*.js -o docs/swagger.json",
    "docs:serve": "swagger-ui-serve docs/swagger.json",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t opnsense-management-api .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f opnsense-api",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:status": "sequelize-cli db:migrate:status",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "backup": "node src/scripts/backup.js",
    "health": "curl -f http://localhost:3000/api/v1/health || exit 1",
    "validate": "npm run lint && npm run format:check && npm run test",
    "prepare": "node -e \"try { require('husky').install() } catch (e) { console.log('Husky not available') }\""
  },
  "keywords": [
    "opnsense",
    "firewall",
    "api",
    "security",
    "monitoring",
    "devops",
    "soc",
    "network-security",
    "automation",
    "rest-api",
    "prometheus",
    "audit",
    "compliance"
  ],
  "author": "Pierpaolo Casati SUPSI Student - OPNsense Management",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "express-slow-down": "^2.0.1",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.5",
    "morgan": "^1.10.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "node-cron": "^3.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8",
    "dayjs": "^1.11.13",
    "uuid": "^11.0.3",
    "dotenv": "^16.4.7",
    "express-async-errors": "^3.1.1",
    "http-status-codes": "^2.3.0",
    "multer": "^1.4.4-lts.1",
    "express-fileupload": "^1.5.1",
    "node-cache": "^5.1.2",
    "prom-client": "^15.1.3",
    "yamljs": "^0.3.0",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pierpaolo-casati/opnsense-management-api"
  },
  "bugs": {
    "url": "https://github.com/pierpaolo-casati/opnsense-management-api/issues"
  },
  "homepage": "https://github.com/pierpaolo-casati/opnsense-management-api#readme",
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup/testSetup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/database/migrations/*.js",
      "!src/database/seeders/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testTimeout": 10000,
    "verbose": true
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "plugin:security/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "commonjs"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "node/no-unpublished-require": "off",
      "node/no-missing-require": "off",
      "security/detect-object-injection": "off"
    },
    "ignorePatterns": ["node_modules/", "coverage/", "logs/", "temp/"]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "quoteProps": "as-needed",
    "bracketSpacing": true,
    "arrowParens": "avoid"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "js,json",
    "ignore": ["logs/*", "temp/*", "tests/*"],
    "delay": "1000"
  }
}