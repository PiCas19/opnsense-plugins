######################################################
# OPNsense Management API (WRAPPER) - .env.template
# Solo variabili necessarie per il wrapper
######################################################

# ======================
# CORE APPLICATION
# ======================
NODE_ENV=production
PORT=3000
API_BASE_URL=http://192.168.216.50:3000
REQUEST_SIZE_LIMIT=10mb
ENABLE_SWAGGER=true
SHUTDOWN_TIMEOUT=10000

# ======================
# LOGGING
# ======================
LOG_LEVEL=info
LOG_FORMAT=json

# ======================
# SECURITY & CORS
# ======================
CORS_ORIGIN=http://192.168.216.50:3000,http://localhost:3000
TRUST_PROXY=1

# ======================
# DATABASE (PostgreSQL)
# ======================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=opnsense
POSTGRES_PASSWORD=CHANGEME_STRONG_DB_PASS
POSTGRES_DB=opnsense_mgmt
POSTGRES_SSL=false

# ======================
# REDIS CACHE
# ======================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_STRONG_REDIS_PASS
REDIS_DB=0
REDIS_TTL=3600
REDIS_CONNECT_TIMEOUT=10000
REDIS_KEEP_ALIVE=30000

# ======================
# OPNSENSE API
# ======================
OPNSENSE_BASE_URL=https://192.168.216.1
OPNSENSE_API_KEY=CHANGEME_OPNSENSE_API_KEY
OPNSENSE_API_SECRET=CHANGEME_OPNSENSE_API_SECRET
OPNSENSE_SSL_VERIFY=false
OPNSENSE_TIMEOUT=30000
OPNSENSE_RETRIES=3
OPNSENSE_RETRY_DELAY=1000

# ======================
# AUTHENTICATION & JWT
# ======================
JWT_SECRET=CHANGEME_JWT_SECRET_MIN_64_CHARACTERS_RANDOM_STRING
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=CHANGEME_COOKIE_SECRET_MIN_32_CHARS
BCRYPT_SALT_ROUNDS=12

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ======================
# MONITORING & METRICS
# ======================
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
# IPs che possono accedere a /metrics (Prometheus LAN)
METRICS_ALLOWED_IPS=192.168.216.100,127.0.0.1

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=500
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_FIREWALL_MAX=200
RATE_LIMIT_MONITORING_MAX=300
RATE_LIMIT_CRITICAL_MAX=10

# ======================
# AUDIT
# ======================
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=2555

# ======================
# DEBUG
# ======================
DEBUG_SQL=false
DEBUG_API_CALLS=false

# ======================
# BUILD INFO (set by CI/CD)
# ======================
BUILD_TIMESTAMP=
GIT_COMMIT=
GIT_BRANCH=
BUILD_NUMBER=