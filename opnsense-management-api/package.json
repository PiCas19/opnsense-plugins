{
  "name": "opnsense-management-api",
  "version": "1.0.0",
  "description": "RESTful API wrapper for OPNsense firewall management with monitoring integration",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js --inspect=0.0.0.0:9229",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write 'src/**/*.js'",
    "docs:generate": "swagger-jsdoc -d swagger.config.js src/routes/*.js -o docs/swagger.json",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t opnsense-management-api .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f opnsense-api",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "backup": "node src/scripts/backup.js",
    "health": "curl -f http://localhost:3000/api/v1/health || exit 1"
  },
  "keywords": [
    "opnsense",
    "firewall",
    "api",
    "security",
    "monitoring",
    "devops",
    "soc",
    "network-security",
    "automation",
    "rest-api"
  ],
  "author": "Pierpaolo Casati",
  "license": "MIT",
  "dependencies": {
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "express-validator": "7.2.0",
    "helmet": "8.0.0",
    "cors": "2.8.5",
    "compression": "1.7.5",
    "morgan": "1.10.0",
    "winston": "3.17.0",
    "winston-daily-rotate-file": "5.0.0",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "axios": "1.7.9",
    "pg": "8.13.1",
    "redis": "4.7.0",
    "sequelize": "6.37.5",
    "node-cron": "3.0.3",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "zod": "3.23.8",
    "dayjs": "1.11.13",
    "uuid": "11.0.3",
    "dotenv": "16.4.7",
    "express-async-errors": "3.1.1",
    "http-status-codes": "2.3.0",
    "node-cache": "5.1.2",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "nodemon": "3.1.7",
    "vitest": "2.1.8",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.4.2",
    "cross-env": "7.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/opnsense-management-api"
  },
  "type": "module",
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  }
}