# =============================================================================
# .env.example - Template for environment variables (OPNsense Monitoring Bridge)
# Copy this file to .env and fill in the appropriate values.
# Do not use sensitive values in this file; use .env for production secrets.
# =============================================================================

# OPNsense Configuration
# Hostname or IP of the OPNsense firewall
OPNSENSE_HOST=192.168.1.1
# OPNsense API key and secret (generate from OPNsense UI)
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here
# Set to false to bypass SSL verification for self-signed certificates
OPNSENSE_VERIFY_SSL=false

# Bridge Configuration
# Host IP for the bridge API (use 0.0.0.0 for all interfaces)
BRIDGE_HOST=0.0.0.0
# Port for the bridge API
BRIDGE_PORT=8443
# Public IP address of the bridge (used for external access)
BRIDGE_IP=172.16.216.10
# Enable SSL for the bridge API
USE_SSL=true

# Network Configuration
# DMZ and LAN network ranges
DMZ_NETWORK=172.16.216.0/24
LAN_NETWORK=192.168.216.0/24

# Security Configuration
# Secret key for generating JWT tokens (use a strong, unique key)
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-change-in-production
# Comma-separated list of allowed IP ranges or addresses
ALLOWED_IPS=172.16.216.0/24,192.168.216.0/24,127.0.0.1
# Allowed CORS origins (use * for all or specify domains)
ALLOWED_ORIGINS=*

# Application Configuration
# Enable debug mode (set to false in production)
DEBUG=false
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Allow startup if OPNsense is unavailable
ALLOW_STARTUP_WITHOUT_OPNSENSE=false

# Monitoring Configuration
# Enable Prometheus metrics endpoint
ENABLE_METRICS=true
# Port for Prometheus metrics
METRICS_PORT=9090

# Rate Limiting
# Maximum requests per period
RATE_LIMIT_REQUESTS=100
# Rate limit period (seconds)
RATE_LIMIT_PERIOD=60

# =============================================================================
# Gmail SMTP Configuration
# =============================================================================
# SMTP server for email notifications
SMTP_SERVER=smtp.gmail.com
# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP credentials
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
# Enable TLS or SSL for SMTP
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Sender email and name
SMTP_FROM_ADDRESS=your-gmail@gmail.com
SMTP_FROM_NAME=OPNsense Bridge DMZ

# =============================================================================
# Notification Recipients
# =============================================================================
# Comma-separated list of admin emails
ADMIN_EMAILS=admin@example.com
# Comma-separated list of security team emails
SECURITY_EMAILS=security@example.com
# Comma-separated list of operations team emails
OPS_EMAILS=ops@example.com
# Comma-separated list of emergency contact emails
EMERGENCY_EMAILS=emergency@example.com

# =============================================================================
# Internal Webhook Configuration (DMZ -> LAN)
# =============================================================================
# Enable internal monitoring webhook
INTERNAL_WEBHOOK_ENABLED=true
# Internal webhook URL and API key
INTERNAL_WEBHOOK_URL=https://192.168.216.100/webhook/opnsense-alerts
INTERNAL_WEBHOOK_API_KEY=your-internal-monitoring-api-key

# Grafana webhook (optional)
GRAFANA_WEBHOOK_ENABLED=false
GRAFANA_WEBHOOK_URL=https://192.168.216.110:3000/api/alerts/webhook
GRAFANA_WEBHOOK_TOKEN=your-grafana-api-token

# Ticketing system webhook (optional)
TICKETING_WEBHOOK_ENABLED=false
TICKETING_WEBHOOK_URL=https://192.168.216.120/api/tickets
TICKETING_WEBHOOK_TOKEN=your-ticketing-system-token

# =============================================================================
# Slack Configuration (Optional - requires internet access from DMZ)
# =============================================================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_DEFAULT_CHANNEL=#dmz-alerts
SLACK_EMERGENCY_CHANNEL=#emergency

# =============================================================================
# Microsoft Teams Configuration (Optional)
# =============================================================================
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=https://your-company.webhook.office.com/webhookb2/your-webhook

# =============================================================================
# Alert Configuration
# =============================================================================
# Thresholds for CPU alerts
CPU_WARNING_THRESHOLD=80
CPU_CRITICAL_THRESHOLD=95
# Thresholds for memory alerts
MEMORY_WARNING_THRESHOLD=85
MEMORY_CRITICAL_THRESHOLD=95
# Thresholds for disk alerts
DISK_WARNING_THRESHOLD=90
DISK_CRITICAL_THRESHOLD=95
# Thresholds for firewall rule alerts
FIREWALL_RULES_WARNING=5
FIREWALL_RULES_CRITICAL=2
# Thresholds for blocked events
BLOCKED_EVENTS_WARNING=1000
BLOCKED_EVENTS_CRITICAL=5000
# Thresholds for security risk scores
RISK_SCORE_WARNING=50
RISK_SCORE_CRITICAL=80
# Thresholds for failed logins
FAILED_LOGINS_WARNING=10
FAILED_LOGINS_CRITICAL=50
# Thresholds for response time (milliseconds)
RESPONSE_TIME_WARNING=2000
RESPONSE_TIME_CRITICAL=5000

# =============================================================================
# Emergency Response Configuration
# =============================================================================
# Emergency blocking settings
EMERGENCY_AUTO_BLOCK=true
EMERGENCY_BLOCK_THRESHOLD=100
EMERGENCY_BULK_LIMIT=1000
EMERGENCY_BLOCK_DURATION=86400
# Emergency notification settings
EMERGENCY_NOTIFICATION_COOLDOWN=0
EMERGENCY_ESCALATION_DELAY=300
EMERGENCY_MAX_RETRIES=5

# =============================================================================
# File Logging Configuration
# =============================================================================
# Alert backup file settings
ALERT_BACKUP_ENABLED=true
ALERT_BACKUP_FILE=/app/logs/alerts_backup.jsonl
ALERT_BACKUP_MAX_SIZE=50MB
ALERT_BACKUP_BACKUP_COUNT=10
# Log rotation settings
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5
EMERGENCY_LOG_BACKUP_COUNT=10
AUDIT_LOG_BACKUP_COUNT=20

# =============================================================================
# DMZ Specific Configuration
# =============================================================================
# Allowed outbound connections from DMZ
DMZ_OUTBOUND_ALLOWED=smtp.gmail.com:587
# Internal networks accessible from DMZ
DMZ_INTERNAL_NETWORKS=192.168.216.0/24
# Offline mode settings
DMZ_OFFLINE_MODE=true
DMZ_ALERT_BUFFER_SIZE=1000
DMZ_RETRY_DELAY=60
DMZ_MAX_RETRY_ATTEMPTS=5
# Performance tuning for DMZ
DMZ_BATCH_NOTIFICATIONS=true
DMZ_BATCH_SIZE=10
DMZ_BATCH_TIMEOUT=30

# =============================================================================
# SSL/TLS Configuration
# =============================================================================
# Paths to SSL certificates
SSL_CERT_PATH=/app/certs/server.crt
SSL_KEY_PATH=/app/certs/server.key
SSL_CA_PATH=/app/certs/ca.crt
# SSL verification settings
SSL_VERIFY_PEER=false
SSL_MIN_VERSION=TLSv1.2

# =============================================================================
# Prometheus Metrics Configuration
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics
PROMETHEUS_NAMESPACE=opnsense_bridge_dmz

# =============================================================================
# Health Check Configuration
# =============================================================================
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_RETRIES=3
OPNSENSE_HEALTH_TIMEOUT=10

# =============================================================================
# Development/Testing Configuration
# =============================================================================
# Enable test mode for development
TEST_MODE=false
TEST_EMAIL_RECIPIENT=test@example.com
TEST_WEBHOOK_URL=https://httpbin.org/post
MOCK_OPNSENSE_API=false
# Debug settings
DEBUG_SMTP=false
DEBUG_WEBHOOKS=false
DEBUG_NOTIFICATIONS=false

# =============================================================================
# Backup and Recovery
# =============================================================================
BACKUP_ENABLED=true
BACKUP_DIRECTORY=/app/backups
BACKUP_RETENTION_DAYS=30
CONFIG_BACKUP_INTERVAL=86400

# =============================================================================
# Timezone Configuration
# =============================================================================
TZ=Europe/Zurich
LOG_TIMEZONE=UTC
ALERT_TIMEZONE=Europe/Zurich