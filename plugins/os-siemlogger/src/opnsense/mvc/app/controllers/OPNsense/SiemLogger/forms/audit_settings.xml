<field>
    <id>siemlogger.audit_settings.audit_enabled</id>
    <label>Enable Auditing</label>
    <type>checkbox</type>
    <help>Enable audit logging for security events</help>
</field>
<field>
    <id>siemlogger.audit_settings.audit_failed_logins</id>
    <label>Audit Failed Logins</label>
    <type>checkbox</type>
    <help>Log failed login attempts</help>
</field>
<field>
    <id>siemlogger.audit_settings.audit_admin_actions</id>
    <label>Audit Admin Actions</label>
    <type>checkbox</type>
    <help>Log administrative actions</help>
</field>
<field>
    <id>siemlogger.audit_settings.audit_privilege_escalation</id>
    <label>Audit Privilege Escalation</label>
    <type>checkbox</type>
    <help>Log privilege escalation events</help>
</field>
<field>
    <id>siemlogger.audit_settings.audit_file_access</id>
    <label>Audit File Access</label>
    <type>checkbox</type>
    <help>Log file access events</help>
</field>
<field>
    <id>siemlogger.audit_settings.suspicious_activity_threshold</id>
    <label>Suspicious Activity Threshold</label>
    <type>text</type>
