<form>
    <field>
        <id>siemlogger.siem_export.export_enabled</id>
        <label>Enable SIEM Export</label>
        <type>checkbox</type>
        <help>Enable exporting logs to an external SIEM system</help>
    </field>
    <field>
        <id>siemlogger.siem_export.export_format</id>
        <label>Export Format</label>
        <type>dropdown</type>
        <style>selectpicker</style>
        <help>Select the format for exported logs</help>
    </field>
    <field>
        <id>siemlogger.siem_export.siem_server</id>
        <label>SIEM Server</label>
        <type>text</type>
        <help>Hostname or IP address of the SIEM server</help>
    </field>
    <field>
        <id>siemlogger.siem_export.siem_port</id>
        <label>SIEM Port</label>
        <type>text</type>
        <help>Port number for the SIEM server (default: 514)</help>
    </field>
    <field>
        <id>siemlogger.siem_export.protocol</id>
        <label>Protocol</label>
        <type>dropdown</type>
        <style>selectpicker</style>
        <help>Transport protocol for SIEM export</help>
    </field>
    <field>
        <id>siemlogger.siem_export.facility</id>
        <label>Syslog Facility</label>
        <type>dropdown</type>
        <style>selectpicker</style>
        <help>Syslog facility for exported logs</help>
    </field>
</form>