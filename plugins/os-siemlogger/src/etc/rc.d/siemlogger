#!/bin/sh
# siemlogger - SiemLogger SIEM daemon script (compatible with configctl)

name="siemlogger"
pidfile="/var/run/${name}.pid"
command="/usr/local/bin/python3.11"
command_args="/usr/local/opnsense/scripts/OPNsense/SiemLogger/siemlogger_engine.py"
config_file="/usr/local/etc/siemlogger/config.json"

siemlogger_prestart()
{
    # Create necessary directories
    [ -d /var/run ] || install -d -m 755 /var/run
    [ -d /var/log/siemlogger ] || install -d -m 755 /var/log/siemlogger
    [ -d /usr/local/etc/siemlogger ] || install -d -m 755 /usr/local/etc/siemlogger
    [ -d /var/db/siemlogger ] || install -d -m 755 /var/db/siemlogger
    
    # Check if Python3 exists
    if [ ! -f "$command" ]; then
        echo "Error: Python3 not found at $command"
        return 1
    fi
    
    # Check if engine script exists
    if [ ! -f "$command_args" ]; then
        echo "Error: Engine script not found at $command_args"
        return 1
    fi
    
    # Check if all required modules exist
    REQUIRED_MODULES="settings_logger export_events health_check"
    SCRIPTS_DIR="/usr/local/opnsense/scripts/OPNsense/SiemLogger"
    
    for module in $REQUIRED_MODULES; do
        if [ ! -f "${SCRIPTS_DIR}/${module}.py" ]; then
            echo "Error: Required module not found: ${SCRIPTS_DIR}/${module}.py"
            return 1
        fi
        chmod +x "${SCRIPTS_DIR}/${module}.py" 2>/dev/null || true
    done
    
    # Set executable permissions on engine
    chmod +x "$command_args" 2>/dev/null || true
    
    # Create basic log files
    touch /var/log/siemlogger/daemon.log
    touch /var/log/siemlogger/engine.log
    touch /var/log/siemlogger/events.log
    touch /var/log/siemlogger/audit.log
    touch /var/log/siemlogger/stats.json
    
    return 0
}

siemlogger_start()
{
    echo "[$(date)] Starting ${name}..." >> /var/log/siemlogger/daemon.log
    
    # Check if already running
    if [ -f "${pidfile}" ]; then
        OLD_PID=$(cat ${pidfile})
        if kill -0 "${OLD_PID}" 2>/dev/null; then
            echo "[$(date)] ${name} is already running with PID ${OLD_PID}." >> /var/log/siemlogger/daemon.log
            echo "${name} is already running as PID ${OLD_PID}"
            return 1
        else
            echo "[$(date)] Removing stale PID file" >> /var/log/siemlogger/daemon.log
            rm -f "${pidfile}"
        fi
    fi
    
    # Export configuration from OPNsense if available
    if [ -f /usr/local/opnsense/scripts/OPNsense/SiemLogger/settings_logger.py ]; then
        echo "[$(date)] Loading configuration..." >> /var/log/siemlogger/daemon.log
        /usr/local/bin/python3.11 /usr/local/opnsense/scripts/OPNsense/SiemLogger/settings_logger.py >> /var/log/siemlogger/daemon.log 2>&1
    else
        echo "[$(date)] Warning: settings_logger.py not found, using default configuration" >> /var/log/siemlogger/daemon.log
    fi
    
    # Create basic config if missing
    if [ ! -f "${config_file}" ]; then
        echo "[$(date)] Creating basic config file..." >> /var/log/siemlogger/daemon.log
        cat > "${config_file}" << 'EOF'
{
  "general": {"enabled": true, "log_level": "INFO"},
  "siem_export": {"export_enabled": false, "export_format": "json"}
}
EOF
        chmod 644 "${config_file}" 2>/dev/null
    fi
    
    # Start the process using daemon utility for better process management
    echo "[$(date)] Starting engine process..." >> /var/log/siemlogger/daemon.log
    
    # Use daemon utility if available, otherwise fallback to manual background process
    if command -v daemon >/dev/null 2>&1; then
        /usr/sbin/daemon -p "${pidfile}" -f "${command}" "${command_args}"
    else
        # Fallback method
        "${command}" "${command_args}" > /var/log/siemlogger/stdout.log 2> /var/log/siemlogger/stderr.log &
        echo $! > "${pidfile}"
    fi
    
    sleep 5
    
    # Check if process is still running
    if [ -f "${pidfile}" ]; then
        NEW_PID=$(cat ${pidfile})
        if kill -0 "${NEW_PID}" 2>/dev/null; then
            echo "[$(date)] ${name} started successfully with PID ${NEW_PID}" >> /var/log/siemlogger/daemon.log
            echo "${name} started successfully as PID ${NEW_PID}"
            return 0
        else
            echo "[$(date)] Failed to start ${name} (PID ${NEW_PID} not alive)" >> /var/log/siemlogger/daemon.log
            echo "[$(date)] Check /var/log/siemlogger/stderr.log for errors" >> /var/log/siemlogger/daemon.log
            echo "Failed to start ${name}"
            rm -f "${pidfile}"
            return 1
        fi
    else
        echo "[$(date)] Failed to start ${name} (no PID file created)" >> /var/log/siemlogger/daemon.log
        echo "Failed to start ${name}"
        return 1
    fi
}

siemlogger_stop()
{
    echo "[$(date)] Stopping ${name}..." >> /var/log/siemlogger/daemon.log
    
    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            # Send TERM signal for graceful shutdown
            echo "[$(date)] Sending TERM signal to PID ${PID}" >> /var/log/siemlogger/daemon.log
            kill -TERM "${PID}"
            
            # Wait for graceful shutdown with timeout
            TIMEOUT=15
            while [ $TIMEOUT -gt 0 ] && kill -0 "${PID}" 2>/dev/null; do
                sleep 1
                TIMEOUT=$((TIMEOUT - 1))
            done
            
            # Force kill if still running
            if kill -0 "${PID}" 2>/dev/null; then
                echo "[$(date)] Process still running, sending KILL signal" >> /var/log/siemlogger/daemon.log
                kill -KILL "${PID}" 2>/dev/null
                sleep 2
            fi
            
            echo "[$(date)] ${name} stopped." >> /var/log/siemlogger/daemon.log
            echo "${name} stopped"
            rm -f "${pidfile}"
            return 0
        else
            echo "[$(date)] PID ${PID} not running, removing stale PID file" >> /var/log/siemlogger/daemon.log
            rm -f "${pidfile}"
            return 0
        fi
    else
        echo "[$(date)] No PID file found. Is ${name} running?" >> /var/log/siemlogger/daemon.log
        echo "${name} is not running"
        return 1
    fi
}

siemlogger_status()
{
    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            echo "${name} is running as PID ${PID}"
            
            # Get additional status info
            if [ -f /var/log/siemlogger/stats.json ]; then
                echo "Statistics available in /var/log/siemlogger/stats.json"
                # Show basic stats if jq is available
                if command -v jq >/dev/null 2>&1; then
                    EVENTS=$(jq -r '.events_processed // 0' /var/log/siemlogger/stats.json 2>/dev/null)
                    THREATS=$(jq -r '.threats_detected // 0' /var/log/siemlogger/stats.json 2>/dev/null)
                    EXPORTED=$(jq -r '.events_exported // 0' /var/log/siemlogger/stats.json 2>/dev/null)
                    echo "Events processed: ${EVENTS}, Threats detected: ${THREATS}, Events exported: ${EXPORTED}"
                fi
            fi
            
            # Show memory usage
            MEMORY=$(ps -o rss= -p "${PID}" 2>/dev/null | awk '{print int($1/1024)"MB"}')
            if [ -n "$MEMORY" ]; then
                echo "Memory usage: ${MEMORY}"
            fi
            
            # Show uptime
            START_TIME=$(ps -o lstart= -p "${PID}" 2>/dev/null)
            if [ -n "$START_TIME" ]; then
                echo "Started: ${START_TIME}"
            fi
            
            return 0
        else
            echo "${name} PID file exists but process is not running"
            return 1
        fi
    else
        echo "${name} is not running"
        return 1
    fi
}

siemlogger_restart()
{
    echo "[$(date)] Restarting ${name}..." >> /var/log/siemlogger/daemon.log
    siemlogger_stop
    sleep 3
    siemlogger_start
}

# Handle different invocation methods (compatible with configctl and service)
case "$1" in
    start)
        siemlogger_prestart && siemlogger_start
        ;;
    stop)
        siemlogger_stop
        ;;
    restart)
        siemlogger_restart
        ;;
    status)
        siemlogger_status
        ;;
    onestart)
        siemlogger_prestart && siemlogger_start
        ;;
    onestop)
        siemlogger_stop
        ;;
    onerestart)
        siemlogger_restart
        ;;
    rcvar)
        echo "# siemlogger"
        echo "siemlogger_enable=${siemlogger_enable:-NO}"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|onestart|onestop|onerestart|rcvar}"
        exit 1
        ;;
esac