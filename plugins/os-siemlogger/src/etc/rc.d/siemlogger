#!/bin/sh
# siemlogger - SiemLogger daemon script (compatible with configctl)

name="siemlogger"
pidfile="/var/run/${name}.pid"
command="/usr/local/bin/python3.11"
command_args="/usr/local/opnsense/scripts/OPNsense/SiemLogger/siemlogger_engine.py"
config_file="/usr/local/etc/siemlogger/config.json"
log_dir="/var/log/siemlogger"
log_file="${log_dir}/service.log"

siemlogger_prestart()
{
    # Create necessary directories
    [ -d /var/run ] || install -d -m 755 /var/run
    [ -d "$log_dir" ] || install -d -m 750 "$log_dir"
    [ -d /usr/local/etc/siemlogger ] || install -d -m 755 /usr/local/etc/siemlogger
    [ -d /var/db/siemlogger ] || install -d -m 755 /var/db/siemlogger

    # Check if Python3 exists
    if [ ! -f "$command" ]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Error: Python3 not found at $command" >> "$log_file"
        return 1
    fi

    # Check if engine script exists
    if [ ! -f "$command_args" ]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Error: Engine script not found at $command_args" >> "$log_file"
        return 1
    fi

    # Check if required modules exist
    REQUIRED_MODULES="settings_logger export_events health_check"
    SCRIPTS_DIR="/usr/local/opnsense/scripts/OPNsense/SiemLogger"

    for module in $REQUIRED_MODULES; do
        if [ ! -f "${SCRIPTS_DIR}/${module}.py" ]; then
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Error: Required module not found: ${SCRIPTS_DIR}/${module}.py" >> "$log_file"
            return 1
        fi
        chmod +x "${SCRIPTS_DIR}/${module}.py" 2>/dev/null || true
    done

    # Set executable permissions on engine
    chmod +x "$command_args" 2>/dev/null || true

    # Create basic config if not exists
    if [ ! -f "$config_file" ]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Creating basic config file..." >> "$log_file"
        cat > "$config_file" << 'EOF'
{
  "general": {
    "enabled": true,
    "log_level": "INFO",
    "max_log_size": 100,
    "event_retention_days": 30,
    "log_sources": ["/var/log/system/latest.log"]
  },
  "siem_export": {
    "export_enabled": false,
    "export_format": "json",
    "siem_server": "",
    "siem_port": 514,
    "protocol": "udp",
    "facility": "local0",
    "tls_cert": "",
    "batch_size": 100,
    "export_interval": 60,
    "enabled_formats": ["json", "syslog", "cef", "leef"]
  },
  "logging_rules": {
    "log_authentication": true,
    "log_authorization": true,
    "log_configuration_changes": true,
    "log_network_events": true,
    "log_system_events": true,
    "log_firewall_events": true,
    "log_vpn_events": true,
    "custom_log_paths": []
  },
  "audit_settings": {
    "audit_enabled": true,
    "audit_failed_logins": true,
    "audit_admin_actions": true,
    "audit_privilege_escalation": true,
    "audit_file_access": false,
    "suspicious_activity_threshold": 5
  },
  "notifications": {
    "email_alerts": false,
    "email_recipients": "",
    "alert_on_failed_logins": true,
    "alert_on_suspicious_activity": true,
    "alert_on_failed_export": true,
    "webhook_url": ""
  },
  "monitoring": {
    "health_check_interval": 300,
    "metrics_collection": true,
    "performance_monitoring": true,
    "disk_usage_threshold": 80
  }
}
EOF
        chmod 644 "$config_file"
    fi

    return 0
}

siemlogger_start()
{
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting ${name}..." >> "$log_file"

    # Check if already running
    if [ -f "${pidfile}" ]; then
        OLD_PID=$(cat "${pidfile}")
        if kill -0 "${OLD_PID}" 2>/dev/null; then
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] ${name} is already running with PID ${OLD_PID}." >> "$log_file"
            echo "${name} is already running as PID ${OLD_PID}"
            return 1
        else
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Removing stale PID file" >> "$log_file"
            rm -f "${pidfile}"
        fi
    fi

    # Export configuration from OPNsense
    if [ -f /usr/local/opnsense/scripts/OPNsense/SiemLogger/settings_logger.py ]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Testing configuration..." >> "$log_file"
        /usr/local/bin/python3.11 /usr/local/opnsense/scripts/OPNsense/SiemLogger/settings_logger.py >> "$log_file" 2>&1 || echo "[$(date '+%Y-%m-%d %H:%M:%S')] Configuration test completed" >> "$log_file"
    fi

    # Start the process using daemon utility
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting engine process..." >> "$log_file"

    if command -v daemon >/dev/null 2>&1; then
        /usr/sbin/daemon -p "${pidfile}" -f "${command}" "${command_args}"
    else
        "${command}" "${command_args}" > /var/log/siemlogger/stdout.log 2> /var/log/siemlogger/stderr.log &
        echo $! > "${pidfile}"
    fi

    sleep 5

    # Check if process is still running
    if [ -f "${pidfile}" ]; then
        NEW_PID=$(cat "${pidfile}")
        if kill -0 "${NEW_PID}" 2>/dev/null; then
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] ${name} started successfully with PID ${NEW_PID}" >> "$log_file"
            echo "${name} started successfully as PID ${NEW_PID}"
            return 0
        else
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Failed to start ${name} (PID ${NEW_PID} not alive)" >> "$log_file"
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Check /var/log/siemlogger/stderr.log for errors" >> "$log_file"
            echo "Failed to start ${name}"
            rm -f "${pidfile}"
            return 1
        fi
    else
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Failed to start ${name} (no PID file created)" >> "$log_file"
        echo "Failed to start ${name}"
        return 1
    fi
}

siemlogger_stop()
{
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Stopping ${name}..." >> "$log_file"

    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] Sending TERM signal to PID ${PID}" >> "$log_file"
            kill -TERM "${PID}"

            TIMEOUT=15
            while [ $TIMEOUT -gt 0 ] && kill -0 "${PID}" 2>/dev/null; do
                sleep 1
                TIMEOUT=$((TIMEOUT - 1))
            done

            if kill -0 "${PID}" 2>/dev/null; then
                echo "[$(date '+%Y-%m-%d %H:%M:%S')] Process still running, sending KILL signal" >> "$log_file"
                kill -KILL "${PID}" 2>/dev/null
                sleep 2
            fi

            echo "[$(date '+%Y-%m-%d %H:%M:%S')] ${name} stopped." >> "$log_file"
            echo "${name} stopped"
            rm -f "${pidfile}"
            return 0
        else
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] PID ${PID} not running, removing stale PID file" >> "$log_file"
            rm -f "${pidfile}"
            return 0
        fi
    else
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] No PID file found. Is ${name} running?" >> "$log_file"
        echo "${name} is not running"
        return 1
    fi
}

siemlogger_status()
{
    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            echo "${name} is running as PID ${PID}"
            if [ -f "$log_dir/stats.json" ]; then
                echo "Statistics available in $log_dir/stats.json"
                if command -v jq >/dev/null 2>&1; then
                    events=$(jq -r '.events_processed // 0' "$log_dir/stats.json" 2>/dev/null)
                    exported=$(jq -r '.events_exported // 0' "$log_dir/stats.json" 2>/dev/null)
                    echo "Events processed: ${events}, Events exported: ${exported}"
                fi
            fi
            return 0
        else
            echo "${name} PID file exists but process is not running"
            return 1
        fi
    else
        echo "${name} is not running"
        return 1
    fi
}

siemlogger_restart()
{
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Restarting ${name}..." >> "$log_file"
    siemlogger_stop
    sleep 3
    siemlogger_start
}

# Handle different invocation methods
case "$1" in
    start)
        siemlogger_prestart && siemlogger_start
        ;;
    stop)
        siemlogger_stop
        ;;
    restart)
        siemlogger_restart
        ;;
    status)
        siemlogger_status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac