#!/bin/sh
# webguard - WebGuard WAF daemon script (compatible with configctl)

name="webguard"
pidfile="/var/run/${name}.pid"
command="/usr/local/bin/python3.11"
command_args="/usr/local/opnsense/scripts/OPNsense/WebGuard/web_guard_engine.py"
config_file="/usr/local/etc/webguard/config.json"

webguard_prestart()
{
    # Create necessary directories
    [ -d /var/run ] || install -d -m 755 /var/run
    [ -d /var/log/webguard ] || install -d -m 755 /var/log/webguard
    [ -d /usr/local/etc/webguard ] || install -d -m 755 /usr/local/etc/webguard
    [ -d /var/db/webguard ] || install -d -m 755 /var/db/webguard
    
    # Check if Python3 exists
    if [ ! -f "$command" ]; then
        echo "Error: Python3 not found at $command"
        return 1
    fi
    
    # Check if engine script exists
    if [ ! -f "$command_args" ]; then
        echo "Error: Engine script not found at $command_args"
        return 1
    fi
    
    # Check if all required modules exist
    REQUIRED_MODULES="update_rules export_config get_waf_stats get_threat_metrics get_metrics get_stats"
    SCRIPTS_DIR="/usr/local/opnsense/scripts/OPNsense/WebGuard"
    
    for module in $REQUIRED_MODULES; do
        if [ ! -f "${SCRIPTS_DIR}/${module}.py" ]; then
            echo "Error: Required module not found: ${SCRIPTS_DIR}/${module}.py"
            return 1
        fi
        chmod +x "${SCRIPTS_DIR}/${module}.py" 2>/dev/null || true
    done
    
    # Set executable permissions on engine
    chmod +x "$command_args" 2>/dev/null || true
    
    return 0
}

webguard_start()
{
    echo "[$(date)] Starting ${name}..." >> /var/log/webguard/daemon.log
    
    # Check if already running
    if [ -f "${pidfile}" ]; then
        OLD_PID=$(cat ${pidfile})
        if kill -0 "${OLD_PID}" 2>/dev/null; then
            echo "[$(date)] ${name} is already running with PID ${OLD_PID}." >> /var/log/webguard/daemon.log
            echo "${name} is already running as PID ${OLD_PID}"
            return 1
        else
            echo "[$(date)] Removing stale PID file" >> /var/log/webguard/daemon.log
            rm -f "${pidfile}"
        fi
    fi
    
    # Export configuration from OPNsense
    if [ -f /usr/local/opnsense/scripts/OPNsense/WebGuard/export_config.py ]; then
        echo "[$(date)] Exporting configuration..." >> /var/log/webguard/daemon.log
        /usr/local/bin/python3.11 /usr/local/opnsense/scripts/OPNsense/WebGuard/export_config.py >> /var/log/webguard/daemon.log 2>&1
    else
        echo "[$(date)] Warning: export_config.py not found, using default configuration" >> /var/log/webguard/daemon.log
    fi
    
    # Update rules first
    if [ -f /usr/local/opnsense/scripts/OPNsense/WebGuard/update_rules.py ]; then
        echo "[$(date)] Updating WAF rules..." >> /var/log/webguard/daemon.log
        /usr/local/bin/python3.11 /usr/local/opnsense/scripts/OPNsense/WebGuard/update_rules.py >> /var/log/webguard/daemon.log 2>&1 || echo "[$(date)] Rules update failed, continuing with existing rules" >> /var/log/webguard/daemon.log
    fi
    
    # Start the process using daemon utility for better process management
    echo "[$(date)] Starting engine process..." >> /var/log/webguard/daemon.log
    
    # Use daemon utility if available, otherwise fallback to manual background process
    if command -v daemon >/dev/null 2>&1; then
        /usr/sbin/daemon -p "${pidfile}" -f "${command}" "${command_args}"
    else
        # Fallback method
        "${command}" "${command_args}" > /var/log/webguard/stdout.log 2> /var/log/webguard/stderr.log &
        echo $! > "${pidfile}"
    fi
    
    sleep 5
    
    # Check if process is still running
    if [ -f "${pidfile}" ]; then
        NEW_PID=$(cat ${pidfile})
        if kill -0 "${NEW_PID}" 2>/dev/null; then
            echo "[$(date)] ${name} started successfully with PID ${NEW_PID}" >> /var/log/webguard/daemon.log
            echo "${name} started successfully as PID ${NEW_PID}"
            return 0
        else
            echo "[$(date)] Failed to start ${name} (PID ${NEW_PID} not alive)" >> /var/log/webguard/daemon.log
            echo "[$(date)] Check /var/log/webguard/stderr.log for errors" >> /var/log/webguard/daemon.log
            echo "Failed to start ${name}"
            rm -f "${pidfile}"
            return 1
        fi
    else
        echo "[$(date)] Failed to start ${name} (no PID file created)" >> /var/log/webguard/daemon.log
        echo "Failed to start ${name}"
        return 1
    fi
}

webguard_stop()
{
    echo "[$(date)] Stopping ${name}..." >> /var/log/webguard/daemon.log
    
    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            # Send TERM signal for graceful shutdown
            echo "[$(date)] Sending TERM signal to PID ${PID}" >> /var/log/webguard/daemon.log
            kill -TERM "${PID}"
            
            # Wait for graceful shutdown with timeout
            TIMEOUT=15
            while [ $TIMEOUT -gt 0 ] && kill -0 "${PID}" 2>/dev/null; do
                sleep 1
                TIMEOUT=$((TIMEOUT - 1))
            done
            
            # Force kill if still running
            if kill -0 "${PID}" 2>/dev/null; then
                echo "[$(date)] Process still running, sending KILL signal" >> /var/log/webguard/daemon.log
                kill -KILL "${PID}" 2>/dev/null
                sleep 2
            fi
            
            echo "[$(date)] ${name} stopped." >> /var/log/webguard/daemon.log
            echo "${name} stopped"
            rm -f "${pidfile}"
            return 0
        else
            echo "[$(date)] PID ${PID} not running, removing stale PID file" >> /var/log/webguard/daemon.log
            rm -f "${pidfile}"
            return 0
        fi
    else
        echo "[$(date)] No PID file found. Is ${name} running?" >> /var/log/webguard/daemon.log
        echo "${name} is not running"
        return 1
    fi
}

webguard_status()
{
    if [ -f "${pidfile}" ]; then
        PID=$(cat "${pidfile}")
        if kill -0 "${PID}" 2>/dev/null; then
            echo "${name} is running as PID ${PID}"
            
            # Get additional status info
            if [ -f /var/log/webguard/stats.json ]; then
                echo "Statistics available in /var/log/webguard/stats.json"
                # Show basic stats if jq is available
                if command -v jq >/dev/null 2>&1; then
                    REQUESTS=$(jq -r '.requests_analyzed // 0' /var/log/webguard/stats.json 2>/dev/null)
                    THREATS=$(jq -r '.threats_blocked // 0' /var/log/webguard/stats.json 2>/dev/null)
                    echo "Requests analyzed: ${REQUESTS}, Threats blocked: ${THREATS}"
                fi
            fi
            
            # Show memory usage
            MEMORY=$(ps -o rss= -p "${PID}" 2>/dev/null | awk '{print int($1/1024)"MB"}')
            if [ -n "$MEMORY" ]; then
                echo "Memory usage: ${MEMORY}"
            fi
            
            return 0
        else
            echo "${name} PID file exists but process is not running"
            return 1
        fi
    else
        echo "${name} is not running"
        return 1
    fi
}

webguard_restart()
{
    echo "[$(date)] Restarting ${name}..." >> /var/log/webguard/daemon.log
    webguard_stop
    sleep 3
    webguard_start
}

# Handle different invocation methods (like deepinspector)
case "$1" in
    start)
        webguard_prestart && webguard_start
        ;;
    stop)
        webguard_stop
        ;;
    restart)
        webguard_restart
        ;;
    status)
        webguard_status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac