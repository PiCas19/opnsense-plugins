<form>
    <field>
        <id>import_blocked.import_file</id>
        <label>Import File</label>
        <type>text</type>
        <help>Select file to import blocked IPs from</help>
        <style>width:100%;</style>
    </field>
    <field>
        <id>import_blocked.format</id>
        <label>File Format</label>
        <type>dropdown</type>
        <help>Format of the import file</help>
        <options>
            <option value="csv">CSV</option>
            <option value="json">JSON</option>
            <option value="txt">Plain Text</option>
        </options>
    </field>
    <field>
        <id>import_blocked.merge_mode</id>
        <label>Merge Mode</label>
        <type>dropdown</type>
        <help>How to handle existing entries</help>
        <options>
            <option value="add">Add New Only</option>
            <option value="replace">Replace All</option>
            <option value="update">Update Existing</option>
        </options>
    </field>
</form>